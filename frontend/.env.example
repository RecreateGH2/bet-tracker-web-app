# Public URL of the FastAPI backend.
#   • In dev: leave unset — the Vite proxy in vite.config.ts forwards
#     /api/* and /ws to localhost:8000.
#   • In prod (Vercel): set to https://<your-backend-host>
#     (no trailing slash). The frontend will call this directly for
#     both REST and WebSocket; the WS URL is derived by swapping
#     http→ws / https→wss.
VITE_API_BASE_URL=
